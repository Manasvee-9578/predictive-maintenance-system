# ============================================================
# Environment Configuration — Predictive Maintenance System
# Copy this file to .env and update values as needed.
# ============================================================

# --- Application ---
APP_NAME=Predictive Maintenance Platform
APP_ENV=development
DEBUG=True

# --- Data Paths ---
DATA_DIR=data/nasa
PROCESSED_DIR=data/processed
MODEL_DIR=models
OUTPUT_DIR=outputs

# --- Model Hyperparameters ---
LSTM_EPOCHS=50
LSTM_BATCH_SIZE=64
LSTM_LEARNING_RATE=0.001
SEQUENCE_LENGTH=30
MAX_RUL=125

# --- Dashboard ---
STREAMLIT_PORT=8501
STREAMLIT_THEME=dark

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=outputs/logs/app.log
